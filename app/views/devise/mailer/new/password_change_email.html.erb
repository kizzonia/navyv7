<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <title>Password Changed – Navy's Credit Union</title>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style type="text/css">
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600&display=swap');

    * { -ms-text-size-adjust:100%; -webkit-text-size-adjust:none; box-sizing:border-box; }
    body { margin:0; padding:0; background-color:#0a1628; font-family:'Source Sans 3', Helvetica, Arial, sans-serif; }
    a { color:#c9a84c; text-decoration:none; }
    a:hover { text-decoration:underline; }

    @media only screen and (max-width:600px) {
      .outer { width:100% !important; }
      .inner { padding:30px 20px !important; }
      .hero-pad { padding:40px 20px !important; }
      .footer-pad { padding:30px 20px !important; }
      .hide { display:none !important; }
      h1 { font-size:26px !important; line-height:32px !important; }
    }
  </style>
</head>
<body bgcolor="#0a1628" style="margin:0;padding:0;background-color:#0a1628;">

  <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#0a1628" style="background-color:#0a1628;">
    <tr>
      <td align="center" style="padding:40px 16px 0;">

        <table class="outer" width="620" cellpadding="0" cellspacing="0" style="width:620px;">

          <!-- ═══ HEADER ═══ -->
          <tr>
            <td style="background-color:#0d1f3c; border-top:4px solid #c9a84c; border-radius:8px 8px 0 0; padding:28px 48px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <img src="https://zoniahome.s3.us-east-2.amazonaws.com/uploads/welcome/logoimg/1/newtry(2).png"
                         alt="Navy's Credit Union" width="150" style="display:block; max-width:150px; height:auto;">
                  </td>
                  <td align="right" style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:11px; color:#8a9bbf; letter-spacing:2px; text-transform:uppercase; font-weight:600;">
                    Security Alert
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ═══ GOLD DIVIDER ═══ -->
          <tr>
            <td style="background:linear-gradient(90deg,#c9a84c 0%,#e8d08a 50%,#c9a84c 100%); height:2px; font-size:0; line-height:0;">&nbsp;</td>
          </tr>

          <!-- ═══ HERO ═══ -->
          <tr>
            <td class="hero-pad" style="background-color:#0d1f3c; padding:56px 48px 48px; text-align:center;">

              <!-- Alert icon -->
              <table width="72" align="center" style="margin:0 auto 28px;" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="background-color:#0a1628; border:2px solid #c9a84c; border-radius:50%; width:72px; height:72px; text-align:center; vertical-align:middle;">
                    <div style="font-size:32px; line-height:72px;">🔑</div>
                  </td>
                </tr>
              </table>

              <h1 style="font-family:'Playfair Display',Georgia,serif; font-size:32px; line-height:40px; color:#ffffff; font-weight:700; margin:0 0 12px; letter-spacing:-0.5px;">
                Password Changed
              </h1>
              <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:13px; color:#c9a84c; letter-spacing:3px; text-transform:uppercase; margin:0 0 32px; font-weight:600;">
                Account Security Notification
              </p>

              <!-- Divider -->
              <table width="60" align="center" style="margin:0 auto 36px;" cellpadding="0" cellspacing="0">
                <tr><td style="background-color:#c9a84c; height:1px; font-size:0;">&nbsp;</td></tr>
              </table>

              <!-- Email -->
              <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:17px; color:#c9a84c; font-weight:600; margin:0 0 8px;">
                <%= @resource.email %>
              </p>
              <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:15px; color:#b0bdd4; line-height:26px; margin:0 0 36px;">
                We're writing to let you know that the password for your Navy's Credit Union account was recently changed. If you made this change, no further action is required.
              </p>

              <!-- Alert box -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
                <tr>
                  <td style="background-color:#0a1628; border:1px solid #1e3a5f; border-left:4px solid #e8b84c; border-radius:4px; padding:20px 24px; text-align:left;">
                    <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:13px; color:#8a9bbf; line-height:22px; margin:0;">
                      <strong style="color:#e8b84c;">⚠ Did not make this change?</strong><br>
                      If you did not change your password, your account may be at risk. Please contact our support team immediately and we will secure your account.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table align="center" style="margin:0 auto;" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="border-radius:4px; background:linear-gradient(135deg,#c9a84c,#e8d08a); box-shadow:0 4px 20px rgba(201,168,76,0.35);">
                    <a href="mailto:support@navyscreditunion.com"
                       style="display:inline-block; font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:14px; font-weight:700; color:#0a1628; text-decoration:none; letter-spacing:1.5px; text-transform:uppercase; padding:16px 40px;">
                      Contact Support
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- ═══ GOLD DIVIDER ═══ -->
          <tr>
            <td style="background:linear-gradient(90deg,#c9a84c 0%,#e8d08a 50%,#c9a84c 100%); height:1px; font-size:0; line-height:0;">&nbsp;</td>
          </tr>

          <!-- ═══ SECURITY NOTICE ═══ -->
          <tr>
            <td class="inner" style="background-color:#091526; padding:28px 48px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td width="20" valign="top" style="padding-top:2px;">
                    <div style="font-size:16px;">🔒</div>
                  </td>
                  <td style="padding-left:12px;">
                    <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:12px; color:#5a6d8c; line-height:20px; margin:0;">
                      <strong style="color:#8a9bbf;">Security Notice:</strong> Navy's Credit Union will never ask for your password, PIN, or full account number via email. If you received this email in error, please
                      <a href="mailto:support@navyscreditunion.com" style="color:#c9a84c;">contact our support team</a> immediately.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ═══ FOOTER ═══ -->
          <tr>
            <td class="footer-pad" style="background-color:#060f1e; border-radius:0 0 8px 8px; padding:36px 48px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding-bottom:20px;">
                    <p style="font-family:'Playfair Display',Georgia,serif; font-size:16px; color:#c9a84c; font-weight:700; letter-spacing:1px; margin:0 0 4px;">
                      Navy's Credit Union
                    </p>
                    <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:10px; color:#3a4f6a; letter-spacing:2px; text-transform:uppercase; margin:0;">
                      Member FDIC &nbsp;·&nbsp; Equal Housing Lender
                    </p>
                  </td>
                </tr>
                <tr>
                  <td style="border-top:1px solid #1a2a42; font-size:0; line-height:0; padding-bottom:20px;">&nbsp;</td>
                </tr>
                <tr>
                  <td align="center">
                    <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:12px; color:#3a4f6a; line-height:22px; margin:0 0 8px;">
                      180 Water St, New York, NY 10038
                    </p>
                    <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:12px; margin:0 0 16px; line-height:22px;">
                      <a href="mailto:support@navyscreditunion.com" style="color:#5a6d8c; text-decoration:none;">support@navyscreditunion.com</a>
                      &nbsp;·&nbsp;
                      <a href="https://www.navyscreditunion.com" style="color:#5a6d8c; text-decoration:none;">navyscreditunion.com</a>
                    </p>
                    <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:11px; color:#2a3a52; line-height:18px; margin:0;">
                      © <%= Time.now.year %> Navy's Credit Union. All rights reserved.<br>
                      This email was sent to <%= @resource.email %> regarding a security change on your account.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>

      </td>
    </tr>
    <tr><td style="height:40px;">&nbsp;</td></tr>
  </table>

</body>
</html>
