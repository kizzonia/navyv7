<!-- ═══ HERO ═══ -->
<tr>
  <td class="hero-pad" style="background-color:#0d1f3c; padding:56px 48px 48px; text-align:center;" bgcolor="#0d1f3c">

    <!-- Icon -->
    <table width="72" align="center" style="margin:0 auto 28px;" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center" style="background-color:#0a1628; border:2px solid #c9a84c; border-radius:50%; width:72px; height:72px; text-align:center; vertical-align:middle;">
          <div style="font-size:32px; line-height:72px;">🔐</div>
        </td>
      </tr>
    </table>

    <h1 style="font-family:'Playfair Display',Georgia,serif; font-size:32px; line-height:40px; color:#ffffff; font-weight:700; margin:0 0 12px; letter-spacing:-0.5px;">
      Transfer Confirmation
    </h1>
    <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:13px; color:#c9a84c; letter-spacing:3px; text-transform:uppercase; margin:0 0 32px; font-weight:600;">
      One Time Password
    </p>

    <!-- Divider -->
    <table width="60" align="center" style="margin:0 auto 36px;" cellpadding="0" cellspacing="0">
      <tr><td style="background-color:#c9a84c; height:1px; font-size:0;">&nbsp;</td></tr>
    </table>

    <% if @user.status? %>

      <!-- OTP Box -->
      <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:14px; color:#b0bdd4; margin:0 0 20px;">
        Your One Time Password for transfer confirmation:
      </p>

      <table align="center" style="margin:0 auto 28px;" cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#0a1628; border:2px solid #c9a84c; border-radius:10px; padding:18px 40px; text-align:center;">
            <p style="font-family:monospace; font-size:36px; font-weight:700; color:#c9a84c; letter-spacing:10px; margin:0; line-height:1;">
              <%= @transfer.otp %>
            </p>
          </td>
        </tr>
      </table>

      <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:15px; color:#b0bdd4; line-height:26px; margin:0 0 28px;">
        Use this code to confirm your transfer. This code is valid for <strong style="color:#fff;">10 minutes</strong> only.
      </p>

      <!-- Security Warning Box -->
      <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:32px;">
        <tr>
          <td style="background-color:#0a1628; border:1px solid #1e3a5f; border-left:4px solid #e8b84c; border-radius:4px; padding:16px 20px; text-align:left;">
            <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:13px; color:#8a9bbf; line-height:22px; margin:0;">
              <strong style="color:#e8b84c;">⚠ Security Notice:</strong><br>
              Never share your OTP with anyone. Navy's Credit Union staff will <strong style="color:#fff;">never</strong> ask for your authentication codes. Your security is our top priority.
            </p>
          </td>
        </tr>
      </table>

    <% else %>

      <!-- Not Applied Box -->
      <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:32px;">
        <tr>
          <td style="background-color:#0a1628; border:1px solid #1e3a5f; border-left:4px solid #e74c3c; border-radius:4px; padding:16px 20px; text-align:left;">
            <p style="font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:13px; color:#8a9bbf; line-height:22px; margin:0;">
              <strong style="color:#e74c3c;">⚠ OTP Not Generated:</strong><br>
              You have not applied for a One Time Password. Please contact our support team to complete your transfer verification.
            </p>
          </td>
        </tr>
      </table>

      <!-- Support CTA -->
      <table align="center" style="margin:0 auto 32px;" cellpadding="0" cellspacing="0">
        <tr>
          <td style="border-radius:4px; background:linear-gradient(135deg,#c9a84c,#e8d08a); box-shadow:0 4px 20px rgba(201,168,76,0.35);">
            <a href="mailto:support@navyscreditunion.com?subject=OTP Support"
               style="display:inline-block; font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:14px; font-weight:700; color:#0a1628; text-decoration:none; letter-spacing:1.5px; text-transform:uppercase; padding:16px 40px;">
              <i class="mdi mdi-headset"></i> Contact Support
            </a>
          </td>
        </tr>
      </table>

    <% end %>

    <!-- Login CTA -->
    <table align="center" style="margin:0 auto;" cellpadding="0" cellspacing="0">
      <tr>
        <td style="border-radius:4px; background:linear-gradient(135deg,#c9a84c,#e8d08a); box-shadow:0 4px 20px rgba(201,168,76,0.35);">
          <%= link_to "Sign In To Your Account", new_user_session_url,
              style: "display:inline-block; font-family:'Source Sans 3',Helvetica,Arial,sans-serif; font-size:14px; font-weight:700; color:#0a1628; text-decoration:none; letter-spacing:1.5px; text-transform:uppercase; padding:16px 40px;" %>
        </td>
      </tr>
    </table>

  </td>
</tr>
<tr><td height="28" style="background-color:#0d1f3c; font-size:0; line-height:0;">&nbsp;</td></tr>
