<div class="container-fluid">

  <!-- Welcome Banner -->
<div style="background:#0d1f3c; border-top:4px solid #c9a84c; border-radius:12px; padding:24px 32px; margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;">
  <div style="display:flex; align-items:center; gap:16px;">
    <div style="width:52px; height:52px; min-width:52px; border-radius:50%; background:rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.3); display:flex; align-items:center; justify-content:center; font-size:24px;">📋</div>
    <div>
      <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:18px; color:#fff; font-weight:700; margin:0 0 4px;">Bill Payments</h4>
      <p style="font-size:13px; color:#8a9bbf; margin:0;">Make paying bills easier and well accounted for — track all your payments in one place.</p>
    </div>
  </div>
  <div style="text-align:right;">
    <p style="font-size:10px; color:#c9a84c; letter-spacing:2px; text-transform:uppercase; font-weight:700; margin:0 0 2px;">Hello</p>
    <p style="font-family:'Playfair Display',Georgia,serif; font-size:16px; color:#fff; font-weight:700; margin:0;"><%= current_user.first_name %></p>
  </div>
</div>

<!-- Breadcrumb -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
  <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:20px; color:#0a1628; font-weight:700; margin:0;">
    <i class="mdi mdi-receipt" style="color:#c9a84c; margin-right:8px;"></i>Bills &amp; Payments
  </h4>
  <nav style="font-size:12px; color:#8a9bbf;">
    <a href="#" style="color:#c9a84c; text-decoration:none; font-weight:600;">Account</a>
    <span style="margin:0 8px;">›</span>
    <span>Bills</span>
  </nav>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">

  <!-- Bills Count -->
  <div class="col-lg-4 col-md-6">
    <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6; position:relative; transition:transform 0.2s ease;">
      <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#9b59b6,#bb8fce);"></div>
      <div style="padding:22px 24px;">
        <div class="d-flex align-items-start justify-content-between mb-3">
          <span style="background:rgba(155,89,182,0.1); color:#8e44ad; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:3px 10px; border-radius:20px; border:1px solid rgba(155,89,182,0.2);">✦ Bills</span>
          <div style="width:40px; height:40px; border-radius:10px; background:rgba(155,89,182,0.08); border:1px solid rgba(155,89,182,0.15); display:flex; align-items:center; justify-content:center;">
            <i class="mdi mdi-receipt" style="font-size:20px; color:#9b59b6;"></i>
          </div>
        </div>
        <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">Total Bill Records</p>
        <% if Bill.where(user_id: current_user.id).exists? %>
          <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:36px; color:#0a1628; font-weight:700; margin:0 0 10px;"><%= Bill.where(user_id: current_user.id).count %></h3>
          <div style="border-top:1px solid #f0f2f5; padding-top:10px;">
            <p style="font-size:12px; color:#8a9bbf; margin:0;"><i class="mdi mdi-check-circle-outline" style="color:#2ecc71; margin-right:4px;"></i>Bills recorded &amp; tracked</p>
          </div>
        <% else %>
          <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:36px; color:#0a1628; font-weight:700; margin:0 0 10px;">0</h3>
          <div style="border-top:1px solid #f0f2f5; padding-top:10px;">
            <p style="font-size:12px; color:#8a9bbf; margin:0;">No bill records yet</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Account Overview -->
  <% @accounts.take(1).each do |a| %>
  <div class="col-lg-4 col-md-6">
    <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6; position:relative; transition:transform 0.2s ease;">
      <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#3498db,#5dade2);"></div>
      <div style="padding:22px 24px;">
        <div class="d-flex align-items-start justify-content-between mb-3">
          <span style="background:rgba(52,152,219,0.1); color:#2980b9; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:3px 10px; border-radius:20px; border:1px solid rgba(52,152,219,0.2);">✦ Overview</span>
          <div style="width:40px; height:40px; border-radius:10px; background:rgba(52,152,219,0.08); border:1px solid rgba(52,152,219,0.15); display:flex; align-items:center; justify-content:center;">
            <i class="mdi mdi-card-account-details-outline" style="font-size:20px; color:#3498db;"></i>
          </div>
        </div>
        <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">Account Number</p>
        <h4 style="font-size:17px; color:#0a1628; font-weight:700; margin:0 0 12px; font-family:monospace;"><%= a.account_number %></h4>
        <div style="background:#f7f8fb; border:1px solid #e8eaf0; border-radius:6px; padding:8px 12px;">
          <p style="font-size:10px; font-weight:700; color:#8a9bbf; text-transform:uppercase; letter-spacing:1px; margin:0 0 2px;">Routing Number</p>
          <p style="font-size:13px; font-weight:700; color:#3498db; font-family:monospace; margin:0;"><%= a.routine_number %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Balance -->
  <div class="col-lg-4 col-md-6">
    <div style="background:#0d1f3c; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.18); border:1px solid #152238; position:relative; transition:transform 0.2s ease;">
      <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a);"></div>
      <div style="padding:22px 24px;">
        <div class="d-flex align-items-start justify-content-between mb-3">
          <span style="background:rgba(201,168,76,0.15); color:#c9a84c; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:3px 10px; border-radius:20px; border:1px solid rgba(201,168,76,0.3);">✦ Balance</span>
          <div style="width:40px; height:40px; border-radius:10px; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); display:flex; align-items:center; justify-content:center;">
            <i class="mdi mdi-wallet-outline" style="font-size:20px; color:#c9a84c;"></i>
          </div>
        </div>
        <p style="font-size:11px; font-weight:700; color:#5a6d8c; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">Available Balance</p>
        <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:30px; color:#fff; font-weight:700; margin:0 0 12px;">$<%= number_with_delimiter(a.balance) %></h3>
        <div style="border-top:1px solid #1a2a42; padding-top:10px; display:flex; align-items:center; justify-content:space-between;">
          <div>
            <p style="font-size:10px; color:#5a6d8c; text-transform:uppercase; letter-spacing:1px; font-weight:600; margin:0 0 2px;">Book Balance</p>
            <p style="font-size:14px; color:#c9a84c; font-weight:700; margin:0;">$<%= number_with_delimiter(a.lbalance) %></p>
          </div>
          <span style="background:rgba(46,204,113,0.12); color:#2ecc71; font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; border:1px solid rgba(46,204,113,0.2);"><i class="mdi mdi-trending-up"></i> Active</span>
        </div>
      </div>
    </div>
  </div>
  <% end %>

</div>

<!-- Bills Table -->
<div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6;">

  <div style="padding:20px 24px; border-bottom:2px solid #f0f2f5; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
    <div style="display:flex; align-items:center; gap:12px;">
      <div style="width:36px; height:36px; border-radius:8px; background:linear-gradient(135deg,#c9a84c,#e8d08a); display:flex; align-items:center; justify-content:center;">
        <i class="mdi mdi-format-list-checks" style="font-size:18px; color:#0a1628;"></i>
      </div>
      <div>
        <h5 style="font-family:'Playfair Display',Georgia,serif; font-size:17px; color:#0a1628; font-weight:700; margin:0;">Recent Bill Payments</h5>
        <p style="font-size:11px; color:#8a9bbf; margin:0;">All recorded bills and payment status</p>
      </div>
    </div>
    <%= link_to new_bill_path, style: "display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:700; color:#c9a84c; text-decoration:none; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); padding:8px 16px; border-radius:6px;" do %>
      <i class="mdi mdi-plus-circle-outline" style="font-size:14px;"></i> Record Bill Payment
    <% end %>
  </div>

  <div style="overflow-x:auto;">
    <table class="table mb-0" id="datatable" style="font-size:13px;">
      <thead>
        <tr style="background:#f7f8fb;">
          <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Name</th>
          <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Service</th>
          <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Amount</th>
          <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Due Date</th>
          <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Status</th>
        </tr>
      </thead>
      <tbody>
        <% if Bill.where(user_id: current_user.id).exists? %>
          <% @bills.each do |t| %>
          <tr style="border-bottom:1px solid #f0f2f5;">
            <td style="padding:14px 20px;">
              <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:36px; height:36px; border-radius:8px; background:rgba(155,89,182,0.08); border:1px solid rgba(155,89,182,0.15); display:flex; align-items:center; justify-content:center;">
                  <i class="mdi mdi-receipt-text-outline" style="color:#9b59b6; font-size:16px;"></i>
                </div>
                <span style="font-size:13px; color:#1a2a42; font-weight:600;"><%= t.name %></span>
              </div>
            </td>
            <td style="padding:14px 20px;"><span style="font-size:13px; color:#5a6d8c;"><%= t.service %></span></td>
            <td style="padding:14px 20px;"><span style="font-size:14px; font-weight:700; color:#c0392b;">- $<%= number_with_delimiter(t.amount) %></span></td>
            <td style="padding:14px 20px;"><span style="font-size:12px; color:#8a9bbf;"><%= t.date.to_datetime.strftime('%b %d, %Y %I:%M%p') %></span></td>
            <td style="padding:14px 20px;">
              <% if t.status? %>
                <span style="background:#eafaf1; color:#1e8449; font-size:11px; font-weight:700; padding:5px 12px; border-radius:20px; border:1px solid rgba(46,204,113,0.25); display:inline-flex; align-items:center; gap:4px;">
                  <i class="mdi mdi-check-circle-outline" style="font-size:12px;"></i> Payment Successful
                </span>
              <% else %>
                <span style="background:#fef9ec; color:#d68910; font-size:11px; font-weight:700; padding:5px 12px; border-radius:20px; border:1px solid rgba(230,176,15,0.25); display:inline-flex; align-items:center; gap:4px;">
                  <i class="mdi mdi-clock-outline" style="font-size:12px;"></i> Pending
                </span>
              <% end %>
            </td>
          </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" style="padding:48px 20px; text-align:center;">
              <i class="mdi mdi-receipt-text-outline" style="font-size:40px; color:#dde2ec; display:block; margin-bottom:12px;"></i>
              <p style="font-size:14px; color:#8a9bbf; margin:0; font-weight:600;">No bill records yet</p>
              <p style="font-size:12px; color:#b0bdd4; margin:4px 0 0;">Start recording your bill payments to track them here</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div style="padding:14px 24px; border-top:1px solid #f0f2f5; display:flex; align-items:center; justify-content:space-between; background:#f7f8fb;">
    <p style="font-size:12px; color:#8a9bbf; margin:0;"><i class="mdi mdi-shield-check-outline" style="color:#c9a84c; margin-right:4px;"></i> All bill payments are securely recorded and tracked</p>
    <p style="font-size:11px; color:#8a9bbf; margin:0; letter-spacing:1px; text-transform:uppercase; font-weight:600;">Navy's Credit Union</p>
  </div>

</div>

</div>
