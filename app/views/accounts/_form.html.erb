<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">

<%= simple_form_for(@account, html: { class: "ncu-form-wrap" }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="ncu-form-header">
    <div>
      <h1>Open Your Account</h1>
      <p>Navy's Credit Union &nbsp;·&nbsp; Secure Application</p>
    </div>
    <div class="ncu-form-header-badge">
      <span>🔒</span>
      <span>256-bit SSL</span>
    </div>
  </div>

  <div class="ncu-gold-bar"></div>
  <div class="ncu-form-body">

    <!-- Account Type -->
    <div class="ncu-form-section">
      <div class="ncu-section-header">
        <div class="ncu-section-icon">🏦</div>
        <div><h3>Account Type</h3><p>Select the account that suits your needs</p></div>
      </div>
      <div class="ncu-field-group">
        <label>Choose Your Preferred Account Type <span class="req">*</span></label>
        <%= f.input :account_type, collection: @plans, label_method: :title,
            value_method: :title, include_blank: false,
            input_html: { class: "ncu-select" },
            wrapper: false, label: false %>
      </div>
    </div>

    <!-- Personal Details -->
    <div class="ncu-form-section">
      <div class="ncu-section-header">
        <div class="ncu-section-icon">👤</div>
        <div><h3>Personal Details</h3><p>Your contact and address information</p></div>
      </div>
      <div class="row">
        <div class="col-md-6">
          <%= f.input :address, required: true, label: "Home Address",
              input_html: { class: "ncu-input", placeholder: "123 Main Street" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :occupation_address, label: "Office Address (Optional)",
              input_html: { class: "ncu-input", placeholder: "Office Address" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :city, required: true, label: "City",
              input_html: { class: "ncu-input", placeholder: "New York" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :state, required: true, label: "State",
              input_html: { class: "ncu-input", placeholder: "NY" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :zip_code, required: true, label: "Postal / Zip Code",
              input_html: { class: "ncu-input", placeholder: "10001" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :avatar, as: :file, label: "Profile Photo",
              input_html: { class: "ncu-file-input" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
      </div>
    </div>

    <!-- Security Details -->
    <div class="ncu-form-section">
      <div class="ncu-section-header">
        <div class="ncu-section-icon">🔐</div>
        <div><h3>Security Details</h3><p>Private information for identity verification</p></div>
      </div>
      <div class="ncu-security-notice">
        🛡 Your information is encrypted and securely stored. Navy's Credit Union will never share your personal details with third parties.
      </div>
      <div class="row">
        <div class="col-md-6">
          <%= f.input :ssn, required: true, label: "Social Security Number / ID Number",
              input_html: { class: "ncu-input", placeholder: "•••-••-••••" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :phone, label: "Phone Number",
              input_html: { class: "ncu-input", placeholder: "+1 (555) 000-0000" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :mmn, label: "Mother's Maiden Name",
              input_html: { class: "ncu-input", placeholder: "Mother's Maiden Name" },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :account_pin, as: :password, label: "Account PIN Code",
              input_html: { class: "ncu-input", placeholder: "••••", maxlength: 6 },
              wrapper_html: { class: "ncu-field-group" } %>
        </div>
      </div>
    </div>

  </div>

  <div class="ncu-form-footer">
    <div class="ncu-submit-area">
      <%= f.button :submit, "Open My Account", class: "ncu-btn-submit" %>
      <div class="ncu-submit-secure">🔒 Secured &amp; Encrypted</div>
    </div>
  </div>

  <div class="ncu-card-foot">
    <span>Member FDIC &nbsp;·&nbsp; Equal Housing Lender</span>
    <div class="ncu-foot-dots"><span></span><span></span><span></span></div>
  </div>

<% end %>
