<div class="container-fluid">


<div class="row">
  <div class="col-12">
    <div class="page-title-box d-sm-flex align-items-center justify-content-between">
      <h4 class="mb-sm-0 font-size-18">Account Profile</h4>

      <div class="page-title-right">
        <ol class="breadcrumb m-0">
          <li class="breadcrumb-item"><a href="javascript: void(0);">Accounts</a></li>
          <li class="breadcrumb-item active">Profile</li>
        </ol>
      </div>
    </div>
  </div>
</div>
  <!-- Page Header -->
<div class="" style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px;">
  <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:20px; color:#0a1628; font-weight:700; margin:0;">
    <i class="mdi mdi-account-circle-outline" style="color:#c9a84c; margin-right:8px;"></i>Account Profile
  </h4>
  <div style="display:flex; gap:10px;">
    <%= link_to edit_account_path(@account), style: "display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:700; color:#0a1628; text-decoration:none; background:linear-gradient(135deg,#c9a84c,#e8d08a); padding:9px 18px; border-radius:6px; box-shadow:0 4px 12px rgba(201,168,76,0.3);" do %>
      <i class="mdi mdi-pencil-outline" style="font-size:14px;"></i> Edit Account
    <% end %>
    <%= link_to accounts_path, style: "display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:700; color:#5a6d8c; text-decoration:none; background:#fff; padding:9px 18px; border-radius:6px; border:1px solid #dde2ec;" do %>
      <i class="mdi mdi-arrow-left" style="font-size:14px;"></i> Back
    <% end %>
  </div>
</div>

<div class="row g-4">

  <!-- LEFT: Profile Card -->
  <div class="col-lg-4">

    <!-- Avatar + Status -->
    <div style="background:#0d1f3c; border-top:4px solid #c9a84c; border-radius:14px; padding:32px 24px; text-align:center; margin-bottom:20px; box-shadow:0 4px 20px rgba(10,22,40,0.18);">
      <div style="width:90px; height:90px; border-radius:50%; border:3px solid rgba(201,168,76,0.4); display:flex; align-items:center; justify-content:center; margin:0 auto 16px; overflow:hidden; background:linear-gradient(135deg,#0a1628,#1a3a6c);">
        <% if @account.avatar? %>
          <%= image_tag @account.avatar_url.to_s, style: "width:100%; height:100%; object-fit:cover;" %>
        <% else %>
          <i class="mdi mdi-account" style="font-size:44px; color:#c9a84c;"></i>
        <% end %>
      </div>
      <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:20px; color:#fff; font-weight:700; margin:0 0 4px;"><%= @account.user.first_name %> <%= @account.user.last_name %></h4>
      <p style="font-size:11px; color:#c9a84c; letter-spacing:2px; text-transform:uppercase; font-weight:700; margin:0 0 6px;"><%= @account.account_type %></p>
      <p style="font-size:11px; color:#5a6d8c; margin:0 0 16px; font-family:monospace;"><%= @account.user.email %></p>
      <div style="background:rgba(46,204,113,0.12); color:#2ecc71; font-size:11px; font-weight:700; padding:5px 16px; border-radius:20px; border:1px solid rgba(46,204,113,0.25); display:inline-flex; align-items:center; gap:4px;">
        <i class="mdi mdi-check-circle" style="font-size:13px;"></i> Active Account
      </div>
    </div>

    <!-- Balance -->
    <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6; margin-bottom:20px;">
      <div style="height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a);"></div>
      <div style="padding:20px 24px;">
        <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 6px;">Available Balance</p>
        <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:28px; color:#0a1628; font-weight:700; margin:0 0 4px;">$<%= number_with_delimiter(@account.balance) %></h3>
        <p style="font-size:11px; color:#8a9bbf; margin:0;"><i class="mdi mdi-trending-up" style="color:#2ecc71; margin-right:4px;"></i>Book Balance: $<%= number_with_delimiter(@account.lbalance) %></p>
      </div>
    </div>

    <!-- Account Numbers -->
    <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6;">
      <div style="height:3px; background:linear-gradient(90deg,#3498db,#5dade2);"></div>
      <div style="padding:20px 24px;">
        <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 12px;">Account Numbers</p>
        <div style="margin-bottom:14px;">
          <p style="font-size:10px; color:#8a9bbf; text-transform:uppercase; letter-spacing:1px; font-weight:600; margin:0 0 3px;">Account Number</p>
          <p style="font-family:monospace; font-size:15px; color:#3498db; font-weight:700; margin:0; letter-spacing:2px;"><%= @account.account_number %></p>
        </div>
        <div>
          <p style="font-size:10px; color:#8a9bbf; text-transform:uppercase; letter-spacing:1px; font-weight:600; margin:0 0 3px;">Routing Number</p>
          <p style="font-family:monospace; font-size:15px; color:#3498db; font-weight:700; margin:0; letter-spacing:2px;"><%= @account.routine_number %></p>
        </div>
      </div>
    </div>

  </div>

  <!-- RIGHT: Detail Panels -->
  <div class="col-lg-8 d-flex flex-column gap-4">

    <!-- Personal Info -->
    <div class="mb-4"  style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6;">
      <div style="padding:18px 24px; border-bottom:2px solid #f0f2f5; display:flex; align-items:center; gap:10px;">
        <div style="width:32px; height:32px; border-radius:8px; background:linear-gradient(135deg,#c9a84c,#e8d08a); display:flex; align-items:center; justify-content:center;">
          <i class="mdi mdi-account-outline" style="font-size:16px; color:#0a1628;"></i>
        </div>
        <div>
          <h6 style="font-family:'Playfair Display',serif; font-size:15px; color:#0a1628; font-weight:700; margin:0;">Personal Information</h6>
          <p style="font-size:11px; color:#8a9bbf; margin:0;">Contact and identity details</p>
        </div>
      </div>
      <div style="padding:8px 24px 16px;">
        <% [
          ["Home Address",       @account.address],
          ["Occupation Address", @account.occupation_address],
          ["Country",            @account.country],
          ["Zip Code",           @account.zip_code],
          ["Date of Birth",      @account.dob],
          ["Account Slug",       @account.slug]
        ].each do |label, value| %>
        <div style="display:flex; align-items:flex-start; justify-content:space-between; padding:11px 0; border-bottom:1px solid #f0f2f5;">
          <span style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1px; text-transform:uppercase; min-width:180px;"><%= label %></span>
          <span style="font-size:13px; color:#1a2a42; font-weight:600; text-align:right;"><%= value.presence || "—" %></span>
        </div>
        <% end %>
      </div>
    </div>

    <!-- Security Details -->
    <div  class="mb-4" style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6;">
      <div style="padding:18px 24px; border-bottom:2px solid #f0f2f5; display:flex; align-items:center; gap:10px;">
        <div style="width:32px; height:32px; border-radius:8px; background:linear-gradient(135deg,#c9a84c,#e8d08a); display:flex; align-items:center; justify-content:center;">
          <i class="mdi mdi-shield-lock-outline" style="font-size:16px; color:#0a1628;"></i>
        </div>
        <div>
          <h6 style="font-family:'Playfair Display',serif; font-size:15px; color:#0a1628; font-weight:700; margin:0;">Security Details</h6>
          <p style="font-size:11px; color:#8a9bbf; margin:0;">Sensitive — keep strictly confidential</p>
        </div>
      </div>
      <div style="padding:8px 24px 16px;">
        <div style="display:flex; align-items:center; justify-content:space-between; padding:11px 0; border-bottom:1px solid #f0f2f5;">
          <span style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1px; text-transform:uppercase;">SSN / ID</span>
          <span style="font-family:monospace; font-size:13px; font-weight:700; background:#fdf3f2; color:#c0392b; padding:3px 10px; border-radius:6px; border:1px solid rgba(231,76,60,0.15);"><%= @account.ssn.to_s.gsub(/\d(?=\d{4})/, '•') %></span>
        </div>
        <div style="display:flex; align-items:center; justify-content:space-between; padding:11px 0; border-bottom:1px solid #f0f2f5;">
          <span style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1px; text-transform:uppercase;"> Mothers Maiden Name</span>
          <span style="font-family:monospace; font-size:13px; color:#8a9bbf;">••••••••</span>
        </div>
        <div style="display:flex; align-items:center; justify-content:space-between; padding:11px 0;">
          <span style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1px; text-transform:uppercase;">Account PIN</span>
          <span style="font-family:monospace; font-size:13px; color:#8a9bbf;">••••••</span>
        </div>
      </div>
    </div>

    <!-- Security Notice -->
    <div style="background:#fff8ec; border:1px solid #f0d98a; border-left:3px solid #c9a84c; border-radius:8px; padding:14px 18px; font-size:12px; color:#7a6020; line-height:1.7;">
      <i class="mdi mdi-shield-alert-outline" style="color:#c9a84c; margin-right:6px;"></i>
      <strong style="color:#1a2a42;">Security Reminder:</strong> Never share your SSN, PIN, or Mother's Maiden Name with anyone. Navy's Credit Union staff will never request these details via email or phone.
    </div>

  </div>
</div>
</div ><!--end container-fluid-->