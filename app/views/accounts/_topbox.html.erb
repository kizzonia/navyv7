<% @accounts.take(1).each do |a| %>
<div class="row justify-content-center g-3">

  <!-- Account Type -->
  <div class="col-lg-4 col-md-6 mb-4">
    <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6; position:relative; transition:transform 0.2s ease;">
      <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a);"></div>
      <div style="padding:24px 24px 20px;">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <span style="background:rgba(201,168,76,0.12); color:#b8892a; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:4px 10px; border-radius:20px; border:1px solid rgba(201,168,76,0.25);">✦ Account</span>
          <div style="width:40px; height:40px; border-radius:10px; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.2); display:flex; align-items:center; justify-content:center;">
            <i class="mdi mdi-account-circle-outline" style="font-size:20px; color:#c9a84c;"></i>
          </div>
        </div>
        <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 6px;">Account Type</p>
        <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:22px; color:#0a1628; font-weight:700; margin:0 0 4px;"><%= a.account_type %></h4>
        <p style="font-size:12px; color:#8a9bbf; margin:0 0 20px;">
          <i class="mdi mdi-bank-outline" style="font-size:13px; margin-right:4px;"></i>
          <%= Account.where(user_id: current_user.id).count %> active account(s)
        </p>
        <div style="border-top:1px solid #f0f2f5; padding-top:16px;">
          <%= link_to account_path(a), style: "font-size:12px; font-weight:700; color:#c9a84c; text-decoration:none; display:flex; align-items:center; gap:6px;" do %>
            <i class="mdi mdi-pencil-outline" style="font-size:14px;"></i>
            View Account Information
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Account Overview -->
  <div class="col-lg-4 col-md-6 mb-4">
    <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6; position:relative; transition:transform 0.2s ease;">
      <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#3498db,#5dade2);"></div>
      <div style="padding:24px 24px 20px;">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <span style="background:rgba(52,152,219,0.1); color:#2980b9; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:4px 10px; border-radius:20px; border:1px solid rgba(52,152,219,0.2);">✦ Overview</span>
          <div style="width:40px; height:40px; border-radius:10px; background:rgba(52,152,219,0.08); border:1px solid rgba(52,152,219,0.15); display:flex; align-items:center; justify-content:center;">
            <i class="mdi mdi-card-account-details-outline" style="font-size:20px; color:#3498db;"></i>
          </div>
        </div>
        <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 6px;">Account Number</p>
        <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:20px; color:#0a1628; font-weight:700; margin:0 0 16px; letter-spacing:1px;"><%= a.account_number %></h4>
        <div style="background:#f7f8fb; border:1px solid #e8eaf0; border-radius:8px; padding:12px 14px;">
          <p style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">Routing Number</p>
          <p style="font-size:15px; font-weight:700; color:#3498db; margin:0; letter-spacing:1px;"><%= a.routine_number %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Balance -->
  <div class="col-lg-4 col-md-6 mb-4">
    <div style="background:#0d1f3c; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.18); border:1px solid #152238; position:relative; transition:transform 0.2s ease;">
      <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a);"></div>
      <div style="padding:24px 24px 20px;">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <span style="background:rgba(201,168,76,0.15); color:#c9a84c; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:4px 10px; border-radius:20px; border:1px solid rgba(201,168,76,0.3);">✦ Balance</span>
          <div style="width:40px; height:40px; border-radius:10px; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); display:flex; align-items:center; justify-content:center;">
            <i class="mdi mdi-wallet-outline" style="font-size:20px; color:#c9a84c;"></i>
          </div>
        </div>
        <p style="font-size:11px; font-weight:700; color:#5a6d8c; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 6px;">Available Balance</p>
        <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:32px; color:#fff; font-weight:700; margin:0 0 4px;">$<%= number_with_delimiter(a.balance) %></h3>
        <div style="border-top:1px solid #1a2a42; margin-top:16px; padding-top:14px; display:flex; align-items:center; justify-content:space-between;">
          <div>
            <p style="font-size:10px; color:#5a6d8c; letter-spacing:1px; text-transform:uppercase; font-weight:600; margin:0 0 3px;">Book Balance</p>
            <p style="font-size:15px; color:#c9a84c; font-weight:700; margin:0;">$<%= number_with_delimiter(a.lbalance) %></p>
          </div>
          <span style="background:rgba(46,204,113,0.12); color:#2ecc71; font-size:11px; font-weight:700; padding:4px 10px; border-radius:20px; border:1px solid rgba(46,204,113,0.2);">
            <i class="mdi mdi-trending-up" style="font-size:12px;"></i> Active
          </span>
        </div>
      </div>
    </div>
  </div>

</div>
<% end %>
