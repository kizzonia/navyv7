

<div class="container-fluid">
  <!-- Page-Title -->

  <% if Account.where(user_id: current_user.id).exists? %>
  <div class="row">
      <div class="col-sm-12">
        <div class="card text-white card-dark">
            <div class="card-body">
                <blockquote class="card-bodyquote mb-0">
                    <p>Welcome To Your Dashboard, Here you can view your transactions and monitor your finance</p>
                    <footer class="blockquote-footer text-white font-14">
                      Hello  <%= current_user.first_name %>
                    </footer>
                </blockquote>
            </div><!--end card-body-->
        </div><!--end card-->
        <br>
          <div class="page-title-box">
              <div class="float-right">
                  <ol class="breadcrumb">
                      <li class="breadcrumb-item"><a href="javascript:void(0);">Account</a></li>
                      <li class="breadcrumb-item"><a href="javascript:void(0);">Dashboard</a></li>
                  </ol>
              </div>
              <h4 class="page-title">Account</h4>
          </div>
          <!--end page-title-box-->
      </div>
      <!--end col-->
  </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="header-title mt-0">Account Overview</h4>
                    <div class="">
                        <div id="ana_dash_1" class="apex-charts"></div>
                    </div>
                </div>
                <!--end card-body-->
            </div>
            <!--end card-->

    </div>
    </div>
    <% @accounts.take(1).each do |a| %>


    <!--end row-->
    <div class="row justify-content-center">
        <div class="col-lg-4">
            <div class="card report-card">
                <div class="card-body">
                  <div class="float-right"><i class="dripicons-user-group report-main-icon"></i></div>
                  <span class="badge badge-success">Account</span>
                        <div class="row">
                            <div class="col-8 align-self-center">
                                <h5 class=""><%= a.account_type %></h5>
                                <p class="text-muted mb-0"><%= link_to "Edit Account Information", edit_account_path(a) %>
                                  <i class="mdi mdi-menu-up text-success font-16"></i></p>
                            </div>
                            <!--end col-->
                            <div class="col-4">  <h4><%= Account.where(user_id: current_user.id).count %>
.</h4></div>
                            <!--end col-->
                        </div>
                        <!--end row-->
                    <!--end icon-contain-->
                </div>
                <!--end card-body-->
            </div>
            <!--end card-->
        </div>
        <!--end col-->
        <div class="col-lg-4">
            <div class="card report-card">
                <div class="card-body">
                    <div class="float-right"><i class="dripicons-meter report-main-icon"></i></div>
                    <span class="badge badge-warning">Overview</span>
                        <div class="row">
                            <div class="col-12 align-self-center">
                                <h5 class="">Account Number: <%= a.account_number %></h5>
                                <p class="text-muted mb-0">Routing Number: <%= a.routine_number %>
                                  <i class="mdi mdi-menu-up text-success font-16"></i></p>
                            </div>
                            <!--end col-->

                            <!--end col-->
                        </div>
                        <!--end row-->
                    <!--end icon-contain-->
                </div>
                <!--end card-body-->
            </div>
            <!--end card-->
        </div>
        <div class="col-lg-4">
            <div class="card report-card">
                <div class="card-body">
                  <div class="float-right">
                    <i class="dripicons-wallet report-main-icon"></i>
                  </div><span class="badge badge-success">Balance</span>

                        <div class="row">
                            <div class="col-6 align-self-center">
                                <h5 class="">Balance</h5>
                                <p class="text-muted mb-0">Book Balance: $<%=a.lbalance %>
                                  <i class="mdi mdi-menu-up text-success font-16"></i></p>
                            </div>
                            <!--end col-->
                            <div class="col-6">
                              <h5>    $ <%=a.lbalance %></h5>
                            </div>
                            <!--end col-->
                        </div>
                        <!--end row-->
                    <!--end icon-contain-->
                </div>
                <!--end card-body-->
            </div>
            <!--end card-->
        </div>


    </div>
    <% end %>
    <!--end col-->
    </div>
    <!--end row-->
<%= render "shared/transactions" %>
    <!--end row-->

<% else %>

<div class="ncu-account-opening">
  <div class="row justify-content-center">
    <div class="col-lg-7 col-md-12 col-sm-12">
      <div class="account-card">

        <div class="card-image">
          <img src="https://homestoragebox.s3.amazonaws.com/uploads/about/abtimg/3/petretirementsavings_About_image_3.jpeg" alt="Open a Bank Account">
          <div class="card-image-overlay"></div>
          <div class="card-image-badge">✦ New Account</div>
          <div class="card-image-label">
            <h2>Begin Your Banking Journey With Us</h2>
          </div>
        </div>

        <div class="ncu-gold-bar"></div>

        <div class="card-body">
          <ul class="ncu-benefits">
            <li><div class="ncu-benefit-icon">🏦</div><div>No monthly maintenance fees for qualified members with direct deposit</div></li>
            <li><div class="ncu-benefit-icon">🛡</div><div>FDIC insured up to $250,000 — your funds are fully protected</div></li>
            <li><div class="ncu-benefit-icon">📱</div><div>24/7 access via online banking, mobile app, and ATM network</div></li>
            <li><div class="ncu-benefit-icon">⚡</div><div>Fast approval — open your account in as little as 5 minutes</div></li>
          </ul>

          <div class="ncu-terms-notice">
            <p>By proceeding, you confirm that you have read and agreed to the <a href="#">Terms & Conditions</a> and <a href="#">Privacy Policy</a> of Navy's Credit Union.</p>
          </div>

          <div class="ncu-cta-area">
            <%= link_to "Open My Account", new_account_path, class: "btn-ncu-open" %>
            <div class="ncu-secure-badge">
              <span class="ncu-secure-icon">🔒</span>
              <span class="ncu-secure-label">256-bit Secure</span>
            </div>
          </div>
        </div>

        <div class="ncu-card-footer">
          <span class="ncu-footer-legal">Member FDIC &nbsp;·&nbsp; Equal Housing Lender</span>
          <div class="ncu-footer-dots"><span></span><span></span><span></span></div>
        </div>

      </div>
    </div>
  </div>
</div>
    <% end %>
