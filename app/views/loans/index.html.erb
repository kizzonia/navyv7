
                <div class="container-fluid">

                  <!-- Page-Title -->
                  <div style="background:#0d1f3c; border-top:4px solid #c9a84c; border-radius:12px; padding:24px 32px; margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;">
                    <div style="display:flex; align-items:center; gap:16px;">
                      <div style="width:52px; height:52px; min-width:52px; border-radius:50%; background:rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.3); display:flex; align-items:center; justify-content:center; font-size:24px;">🏦</div>
                      <div>
                        <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:18px; color:#fff; font-weight:700; margin:0 0 4px;">Welcome to Navy's Credit Union!</h4>
                        <p style="font-size:13px; color:#8a9bbf; margin:0; line-height:1.6; max-width:480px;">We're excited to support your business's financial journey. Our loan options are tailored to fit your unique needs — from startup funding to expansion capital.</p>
                      </div>
                    </div>
                    <div style="text-align:right;">
                      <p style="font-size:10px; color:#c9a84c; letter-spacing:2px; text-transform:uppercase; font-weight:700; margin:0 0 2px;">Hello</p>
                      <p style="font-family:'Playfair Display',Georgia,serif; font-size:16px; color:#fff; font-weight:700; margin:0;"><%= current_user.first_name %></p>
                    </div>
                  </div>

                  <!-- Breadcrumb -->
                  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
                    <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:20px; color:#0a1628; font-weight:700; margin:0;">
                      <i class="mdi mdi-currency-usd" style="color:#c9a84c; margin-right:8px;"></i>Enterprise Loans
                    </h4>
                    <nav style="font-size:12px; color:#8a9bbf;">
                      <%= link_to loans_path, style: "color:#c9a84c; text-decoration:none; font-weight:600;" do %>Money Market<% end %>
                      <span style="margin:0 8px;">›</span>
                      <span>Loan Request</span>
                    </nav>
                  </div>

                  <div class="row">

                    <% @packages.each do |a| %>
                    <div class="col-lg-4">
                      <div class="card report-card">
                        <div class="card-body">
                          <div class="float-right"><i class="dripicons-user-group report-main-icon"></i></div>
                          <span class="badge badge-success">Request Now</span>
                          <div class="row">
                            <div class="col-8 align-self-center">
                              <h5 class=""><%= link_to  a.title, a %></h5>

                            </div>
                            <!--end col-->
                            <div class="col-4">  <h4><%= a.rate %>
                              .</h4></div>
                              <!--end col-->
                            </div>
                            <div class="row">
                              <div class="col-12">
                                <p class="text-muted mb-0"><%= a.sub_title %>
                                  <i class="mdi mdi-menu-up text-success font-16"></i>  <%= link_to "View More", a %></p>
                                </div>
                                <br>
                                <%= link_to new_loan_path, class: "btn btn-dark waves-effect waves-light text-center col-12" do %>
                                Apply now <i class="ti-arrow-right"></i><% end %>

                              </div>
                              <!--end row-->
                              <!--end icon-contain-->
                            </div>
                            <!--end card-body-->
                          </div>
                          <!--end card-->
                        </div>
                        <% end %>


                      </div>

                    </div>
