<div class="container-fluid">


  <!-- Welcome Banner -->
  <div style="background:#0d1f3c; border-top:4px solid #c9a84c; border-radius:12px; padding:24px 32px; margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;">
    <div style="display:flex; align-items:center; gap:16px;">
      <div style="width:52px; height:52px; min-width:52px; border-radius:50%; background:rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.3); display:flex; align-items:center; justify-content:center; font-size:24px;">🏦</div>
      <div>
        <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:18px; color:#fff; font-weight:700; margin:0 0 4px;">Welcome to Navy's Credit Union!</h4>
        <p style="font-size:13px; color:#8a9bbf; margin:0; line-height:1.6; max-width:480px;">We're excited to support your business's financial journey. Our loan options are tailored to fit your unique needs — from startup funding to expansion capital.</p>
      </div>
    </div>
    <div style="text-align:right;">
      <p style="font-size:10px; color:#c9a84c; letter-spacing:2px; text-transform:uppercase; font-weight:700; margin:0 0 2px;">Hello</p>
      <p style="font-family:'Playfair Display',Georgia,serif; font-size:16px; color:#fff; font-weight:700; margin:0;"><%= current_user.first_name %></p>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
    <h4 style="font-family:'Playfair Display',Georgia,serif; font-size:20px; color:#0a1628; font-weight:700; margin:0;">
      <i class="mdi mdi-currency-usd" style="color:#c9a84c; margin-right:8px;"></i>Enterprise Loans
    </h4>
    <nav style="font-size:12px; color:#8a9bbf;">
      <%= link_to loans_path, style: "color:#c9a84c; text-decoration:none; font-weight:600;" do %>Money Market<% end %>
      <span style="margin:0 8px;">›</span>
      <span>Loan Request</span>
    </nav>
  </div>

  <!-- Stat Cards -->
  <div class="row g-3 mb-4">

    <!-- Active Loans -->
    <div class="col-lg-4 col-md-6">
      <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6; position:relative; transition:transform 0.2s ease;">
        <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#2ecc71,#58d68d);"></div>
        <div style="padding:22px 24px;">
          <div class="d-flex align-items-start justify-content-between mb-3">
            <span style="background:rgba(46,204,113,0.1); color:#1e8449; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:3px 10px; border-radius:20px; border:1px solid rgba(46,204,113,0.2);">✦ Enterprise Loans</span>
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(46,204,113,0.08); border:1px solid rgba(46,204,113,0.15); display:flex; align-items:center; justify-content:center;">
              <i class="mdi mdi-currency-usd" style="font-size:20px; color:#2ecc71;"></i>
            </div>
          </div>
          <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">Active Loans</p>
          <% if Loan.where(user_id: current_user.id).exists? %>
            <% @loans.take(1).each do |a| %>
            <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:32px; color:#0a1628; font-weight:700; margin:0 0 10px;"><%= Loan.where(user_id: current_user.id).count %></h3>
            <div style="border-top:1px solid #f0f2f5; padding-top:10px; display:flex; align-items:center; justify-content:space-between;">
              <p style="font-size:12px; color:#8a9bbf; margin:0;">Budget: <strong style="color:#1a2a42;">$<%= number_with_delimiter(a.budget) %></strong></p>
              <%= link_to new_contact_path, style: "font-size:11px; color:#c9a84c; font-weight:700; text-decoration:none;" do %>Consultation →<% end %>
            </div>
            <% end %>
          <% else %>
            <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:32px; color:#0a1628; font-weight:700; margin:0 0 10px;">0</h3>
            <p style="font-size:12px; color:#8a9bbf; margin:0;">No active loans yet</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Account Overview -->
    <% @accounts.take(1).each do |a| %>
    <div class="col-lg-4 col-md-6">
      <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6; position:relative; transition:transform 0.2s ease;">
        <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#3498db,#5dade2);"></div>
        <div style="padding:22px 24px;">
          <div class="d-flex align-items-start justify-content-between mb-3">
            <span style="background:rgba(52,152,219,0.1); color:#2980b9; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:3px 10px; border-radius:20px; border:1px solid rgba(52,152,219,0.2);">✦ Overview</span>
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(52,152,219,0.08); border:1px solid rgba(52,152,219,0.15); display:flex; align-items:center; justify-content:center;">
              <i class="mdi mdi-card-account-details-outline" style="font-size:20px; color:#3498db;"></i>
            </div>
          </div>
          <p style="font-size:11px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">Account Number</p>
          <h4 style="font-size:18px; color:#0a1628; font-weight:700; margin:0 0 12px; font-family:monospace;"><%= a.account_number %></h4>
          <div style="background:#f7f8fb; border:1px solid #e8eaf0; border-radius:6px; padding:8px 12px;">
            <p style="font-size:10px; font-weight:700; color:#8a9bbf; text-transform:uppercase; letter-spacing:1px; margin:0 0 2px;">Routing Number</p>
            <p style="font-size:13px; font-weight:700; color:#3498db; font-family:monospace; margin:0;"><%= a.routine_number %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Balance -->
    <div class="col-lg-4 col-md-6">
      <div style="background:#0d1f3c; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.18); border:1px solid #152238; position:relative; transition:transform 0.2s ease;">
        <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a);"></div>
        <div style="padding:22px 24px;">
          <div class="d-flex align-items-start justify-content-between mb-3">
            <span style="background:rgba(201,168,76,0.15); color:#c9a84c; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:3px 10px; border-radius:20px; border:1px solid rgba(201,168,76,0.3);">✦ Balance</span>
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); display:flex; align-items:center; justify-content:center;">
              <i class="mdi mdi-wallet-outline" style="font-size:20px; color:#c9a84c;"></i>
            </div>
          </div>
          <p style="font-size:11px; font-weight:700; color:#5a6d8c; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">Available Balance</p>
          <h3 style="font-family:'Playfair Display',Georgia,serif; font-size:30px; color:#fff; font-weight:700; margin:0 0 12px;">$<%= number_with_delimiter(a.balance) %></h3>
          <div style="border-top:1px solid #1a2a42; padding-top:10px; display:flex; align-items:center; justify-content:space-between;">
            <div>
              <p style="font-size:10px; color:#5a6d8c; text-transform:uppercase; letter-spacing:1px; font-weight:600; margin:0 0 2px;">Book Balance</p>
              <p style="font-size:14px; color:#c9a84c; font-weight:700; margin:0;">$<%= number_with_delimiter(a.lbalance) %></p>
            </div>
            <span style="background:rgba(46,204,113,0.12); color:#2ecc71; font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; border:1px solid rgba(46,204,113,0.2);">
              <i class="mdi mdi-trending-up"></i> Active
            </span>
          </div>
        </div>
      </div>
    </div>
    <% end %>

  </div>

  <!-- Loan Activity Table -->
  <div style="background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(10,22,40,0.08); border:1px solid #eef1f6;">

    <div style="padding:20px 24px; border-bottom:2px solid #f0f2f5; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
      <div style="display:flex; align-items:center; gap:12px;">
        <div style="width:36px; height:36px; border-radius:8px; background:linear-gradient(135deg,#c9a84c,#e8d08a); display:flex; align-items:center; justify-content:center;">
          <i class="mdi mdi-format-list-bulleted" style="font-size:18px; color:#0a1628;"></i>
        </div>
        <div>
          <h5 style="font-family:'Playfair Display',Georgia,serif; font-size:17px; color:#0a1628; font-weight:700; margin:0;">Recent Loan Activity</h5>
          <p style="font-size:11px; color:#8a9bbf; margin:0;">All loan applications and status</p>
        </div>
      </div>
      <%= link_to new_loan_path, style: "display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:700; color:#c9a84c; text-decoration:none; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); padding:8px 16px; border-radius:6px;" do %>
        <i class="mdi mdi-plus-circle-outline" style="font-size:14px;"></i> Request A Loan
      <% end %>
    </div>

    <div style="overflow-x:auto;">
      <table class="table mb-0" id="datatable" style="font-size:13px;">
        <thead>
          <tr style="background:#f7f8fb;">
            <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Business</th>
            <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Budget</th>
            <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Awarded</th>
            <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Interest</th>
            <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Date</th>
            <th style="font-size:10px; font-weight:700; color:#8a9bbf; letter-spacing:1.5px; text-transform:uppercase; padding:12px 20px; border:none;">Status</th>
          </tr>
        </thead>
        <tbody>
          <% if Loan.where(user_id: current_user.id).exists? %>
            <% @loans.each do |l| %>
            <tr style="border-bottom:1px solid #f0f2f5;">
              <td style="padding:14px 20px;">
                <p style="font-size:13px; color:#1a2a42; font-weight:600; margin:0 0 2px;"><%= l.business_name %></p>
                <p style="font-size:11px; color:#8a9bbf; margin:0;">Project: <%= l.project_name %></p>
              </td>
              <td style="padding:14px 20px;">
                <span style="font-size:13px; font-weight:700; color:#1a2a42;">$<%= number_with_delimiter(l.budget) %></span>
              </td>
              <td style="padding:14px 20px;">
                <span style="font-size:13px; font-weight:700; color:#1e8449;">$<%= number_with_delimiter(l.amount) %></span>
              </td>
              <td style="padding:14px 20px;">
                <span style="font-size:13px; color:#5a6d8c;"><%= l.interest %>%</span>
              </td>
              <td style="padding:14px 20px;">
                <span style="font-size:12px; color:#8a9bbf;"><%= l.date.strftime('%b %d, %Y') rescue l.date %></span>
              </td>
              <td style="padding:14px 20px;">
                <% if l.status? %>
                  <%= link_to l, style: "background:#eafaf1; color:#1e8449; font-size:11px; font-weight:700; padding:4px 12px; border-radius:20px; border:1px solid rgba(46,204,113,0.25); text-decoration:none; display:inline-flex; align-items:center; gap:4px;" do %>
                    <i class="mdi mdi-check-circle-outline" style="font-size:12px;"></i> Active
                  <% end %>
                <% else %>
                  <%= link_to l, style: "background:#fef9ec; color:#d68910; font-size:11px; font-weight:700; padding:4px 12px; border-radius:20px; border:1px solid rgba(230,176,15,0.25); text-decoration:none; display:inline-flex; align-items:center; gap:4px;" do %>
                    <i class="mdi mdi-clock-outline" style="font-size:12px;"></i> Review In Progress
                  <% end %>
                <% end %>
              </td>
            </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" style="padding:48px 20px; text-align:center;">
                <i class="mdi mdi-currency-usd-off" style="font-size:40px; color:#dde2ec; display:block; margin-bottom:12px;"></i>
                <p style="font-size:14px; color:#8a9bbf; margin:0; font-weight:600;">No loan applications yet</p>
                <p style="font-size:12px; color:#b0bdd4; margin:4px 0 0;">Your loan history will appear here once you apply</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div style="padding:14px 24px; border-top:1px solid #f0f2f5; display:flex; align-items:center; justify-content:space-between; background:#f7f8fb;">
      <p style="font-size:12px; color:#8a9bbf; margin:0;"><i class="mdi mdi-shield-check-outline" style="color:#c9a84c; margin-right:4px;"></i> All loan applications are reviewed within 2–3 business days</p>
      <p style="font-size:11px; color:#8a9bbf; margin:0; letter-spacing:1px; text-transform:uppercase; font-weight:600;">Navy's Credit Union</p>
    </div>

  </div>


              </div>

              <div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title mt-0" id="myLargeModalLabel">Request Loans</h5>
                      <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                    </div>
                    <div class="modal-body">
                      <div class="row">
                        <div class="col-sm-12">
                          <div class="card text-white card-dark">
                            <div class="card-body">
                              <blockquote class="card-bodyquote mb-0">
                                <p>
                                  Welcome to Loan Application! Please fill out the form to begin your
                                  investment journey. By proceeding, you agree to our terms and conditions.
                                  Upon completion, a dedicated broker will attend to your account to provide personalized assistance and guidance.
                                  Thank you for choosing us to help you achieve your financial goals</p>
                                  <footer class="blockquote-footer text-white font-14">
                                    Hello  <%= current_user.first_name %>
                                  </footer>
                                </blockquote>
                              </div><!--end card-body-->
                            </div><!--end card-->
                          </div>
                        </div>
                        <div class="row justify-content-center">
                          <div class="col-12">
                            <%# <%= render 'form', loan: @loan %> %>

                          </div>
                        </div>

                      </div>
                    </div><!-- /.modal-content -->
                  </div><!-- /.modal-dialog -->
                </div><!-- /.modal -->
