<div class="container-fluid">

<div class="row justify-content-center">
  <div class="col-8">
    <br><br><br><br><br>
    <h4 class="text-center mt-0 mb-2  header-title">Select Method Of Transfer </h4>

  </div>

</div>
<div class="row justify-content-center">
    <div class="col-10">
        <div class="row">


        <div class="col-md-12">
            <div class="card card-border">
                <div class="card-body">
                    <h4 class="card-title mt-0">Wire Transfer</h4>
                    <p class="card-subtitle mb-2">Make Quick and Secured  International  & Domestic Transfers  </p>
                    <p class="card-text text-muted">wires transfer can take a few days.
                      Many domestic wire transfers can be completed within 24 hours (especially if transfers
                       occur between accounts at the same financial institution). But international wire transfers may take longer.
                    </p>
                    <button type="button" class="btn btn-dark waves-effect waves-light" data-toggle="modal" data-animation="bounce" data-target=".bs-example-modal-lg">Click here  to continue</button>

                </div><!--end card -body-->
            </div><!--end card-->
    </div>
      </div>
      <div class="row">


      <div class="col-md-12">
          <div class="card card-border">
              <div class="card-body">
                  <h4 class="card-title mt-0">Inter-Bank & Domestic  Transfer</h4>
                  <p class="card-subtitle mb-2"> Transfer funds to family and friends domestically  </p>
                  <p class="card-text text-muted">
                    Please note that domestic & ACH Transfers may take upto 3 business days to proccess
                  </p>
                  <button type="button" class=" card-link btn btn-dark waves-effect waves-light" data-toggle="modal" data-animation="bounce" data-target=".bs-example-modal-lg">Click here  to continue</button>

              </div><!--end card -body-->
          </div><!--end card-->
  </div>
    </div>

</div>
</div>
</div>

<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
<div class="modal-content" style="border:none; border-radius:16px; overflow:hidden; box-shadow:0 20px 60px rgba(10,22,40,0.2);">

  <!-- Modal Header -->
  <div style="background:#0d1f3c; border-top:4px solid #c9a84c; padding:20px 28px; display:flex; align-items:center; justify-content:space-between;">
    <div style="display:flex; align-items:center; gap:12px;">
      <div style="width:38px; height:38px; border-radius:8px; background:linear-gradient(135deg,#c9a84c,#e8d08a); display:flex; align-items:center; justify-content:center;">
        <i class="mdi mdi-bank-transfer" style="font-size:20px; color:#0a1628;"></i>
      </div>
      <div>
        <h5 style="font-family:'Playfair Display',Georgia,serif; font-size:18px; color:#fff; font-weight:700; margin:0 0 2px;">Fund Transfer</h5>
        <p style="font-size:10px; color:#8a9bbf; margin:0; letter-spacing:1.5px; text-transform:uppercase;">Navy's Credit Union &nbsp;·&nbsp; Secure</p>
      </div>
    </div>
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"
      style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:6px; color:#8a9bbf; font-size:18px; width:32px; height:32px; display:flex; align-items:center; justify-content:center; padding:0; opacity:1;">
      ×
    </button>
  </div>

  <!-- Gold bar -->
  <div style="height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a,#c9a84c);"></div>

  <!-- Modal Body -->
  <div class="modal-body" style="padding:0; background:#f7f8fb;">
    <div class="col-12" style="padding:0;">
      <%= render 'form', transfer: @transfer %>
    </div>
  </div>

</div>
</div>
</div><!-- /.modal -->
