<style>
  .transfer-form-wrap { max-width:780px; margin:0 auto; }
  .tf-header { background:#0d1f3c; border-top:4px solid #c9a84c; border-radius:12px 12px 0 0; padding:28px 36px; display:flex; align-items:center; justify-content:space-between; }
  .tf-header h1 { font-family:'Playfair Display',Georgia,serif; font-size:22px; color:#fff; font-weight:700; margin:0 0 4px; }
  .tf-header p { font-size:11px; color:#8a9bbf; margin:0; letter-spacing:1px; text-transform:uppercase; }
  .tf-header-badge { background:rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.3); border-radius:8px; padding:10px 14px; text-align:center; }
  .tf-gold-bar { height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a,#c9a84c); }
  .tf-body { background:#fff; padding:32px 36px 0; }
  .tf-footer-area { background:#fff; padding:0 36px 36px; }
  .tf-section { margin-bottom:28px; }
  .tf-section-header { display:flex; align-items:center; gap:12px; margin:0 0 20px; padding-bottom:14px; border-bottom:2px solid #e8eaf0; }
  .tf-section-icon { width:34px; height:34px; min-width:34px; border-radius:8px; background:linear-gradient(135deg,#c9a84c,#e8d08a); display:flex; align-items:center; justify-content:center; font-size:15px; }
  .tf-section-header h5 { font-family:'Playfair Display',Georgia,serif; font-size:16px; color:#0a1628; font-weight:700; margin:0 0 2px; }
  .tf-section-header p { font-size:11px; color:#8a9bbf; margin:0; }
  .transfer-form-wrap .form-control, .transfer-form-wrap .form-select { border:1.5px solid #dde2ec !important; border-radius:6px !important; font-size:13px !important; color:#1a2a42 !important; padding:11px 14px !important; height:auto !important; box-shadow:none !important; transition:border-color 0.2s, box-shadow 0.2s !important; }
  .transfer-form-wrap .form-control:focus, .transfer-form-wrap .form-select:focus { border-color:#c9a84c !important; box-shadow:0 0 0 3px rgba(201,168,76,0.12) !important; }
  .transfer-form-wrap label { font-size:11px !important; font-weight:700 !important; color:#5a6d8c !important; letter-spacing:1.2px !important; text-transform:uppercase !important; margin-bottom:6px !important; }
  .tf-amount-wrap { position:relative; }
  .tf-amount-wrap .tf-currency { position:absolute; left:4px; top:50%; transform:translateY(-50%); font-size:15px; font-weight:400; color:#c9a84c; pointer-events:none; z-index:1; }
  .tf-amount-wrap input { padding-left:30px !important; font-size:18px !important; font-weight:700 !important; }
  .tf-pin-wrap { position:relative; }
  .tf-pin-wrap i { position:absolute; left:14px; top:50%; transform:translateY(-50%); font-size:16px; color:#c9a84c; pointer-events:none; z-index:1; }
  .tf-pin-wrap input { padding-left:40px !important; letter-spacing:6px !important; }
  .tf-security-notice { background:#fff8ec; border:1px solid #f0d98a; border-left:3px solid #c9a84c; border-radius:6px; padding:12px 16px; margin-bottom:20px; font-size:12px; color:#7a6020; line-height:1.6; }
  .tf-card-footer { background:#0a1628; border-radius:0 0 12px 12px; padding:14px 36px; display:flex; align-items:center; justify-content:space-between; }
  .tf-card-footer span { font-size:10px; color:#3a4f6a; letter-spacing:1.5px; text-transform:uppercase; font-weight:600; }
  @media (max-width:576px) {
    .tf-header, .tf-body, .tf-footer-area, .tf-card-footer { padding-left:20px; padding-right:20px; }
    .tf-header { flex-direction:column; gap:16px; text-align:center; }
  }
</style>

<div class="transfer-form-wrap">

  <%= simple_form_for(@transfer) do |f| %>
    <%= f.error_notification %>
    <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

    <!-- Header -->

    <div class="tf-gold-bar"></div>

    <div class="tf-body">

      <!-- Transfer Type -->
      <div class="tf-section">
        <div class="tf-section-header">
          <div class="tf-section-icon">🏦</div>
          <div><h5>Transfer Type</h5><p>Select your transfer method</p></div>
        </div>
        <%= f.input :transfer_type, as: :select,
            collection: ["Wire Transfer", "Domestic/ACH"],
            label: "Transfer Type",
            input_html: { class: "form-select form-control" },
            wrapper_html: { class: "form-group mb-3" } %>
      </div>

      <!-- Beneficiary Details -->
      <div class="tf-section">
        <div class="tf-section-header">
          <div class="tf-section-icon">👤</div>
          <div><h5>Beneficiary Details</h5><p>Recipient's banking information</p></div>
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <%= f.input :account_name, label: "Beneficiary Full Name",
                placeholder: "Enter beneficiary full name",
                input_html: { class: "form-control" },
                wrapper_html: { class: "form-group" } %>
          </div>
          <div class="col-md-6">
            <%= f.input :bank_name, label: "Beneficiary Bank",
                placeholder: "Enter bank name",
                input_html: { class: "form-control" },
                wrapper_html: { class: "form-group" } %>
          </div>
          <div class="col-md-6">
            <%= f.input :account_number, label: "Account Number",
                placeholder: "Enter account number",
                input_html: { class: "form-control", style: "font-family:monospace; letter-spacing:2px;" },
                wrapper_html: { class: "form-group" } %>
          </div>
          <div class="col-md-6">
            <%= f.input :routine_number, label: "Routing Number",
                placeholder: "Enter routing number",
                input_html: { class: "form-control", style: "font-family:monospace; letter-spacing:2px;" },
                wrapper_html: { class: "form-group" } %>
          </div>
          <div class="col-md-6">
            <%= f.input :country, as: :select,
                collection: ["Afghanistan","Albania","Algeria","Andorra","Angola","Argentina","Armenia","Australia","Austria","Azerbaijan","Bahamas","Bahrain","Bangladesh","Barbados","Belarus","Belgium","Belize","Benin","Bhutan","Bolivia","Bosnia and Herzegowina","Botswana","Brazil","Brunei Darussalam","Bulgaria","Burkina Faso","Burundi","Cambodia","Cameroon","Canada","Cape Verde","Chile","China","Colombia","Congo","Costa Rica","Croatia","Cuba","Cyprus","Czech Republic","Denmark","Dominican Republic","Ecuador","Egypt","El Salvador","Estonia","Ethiopia","Fiji","Finland","France","Gabon","Gambia","Georgia","Germany","Ghana","Greece","Guatemala","Guinea","Guyana","Haiti","Honduras","Hong Kong","Hungary","Iceland","India","Indonesia","Iran, Islamic Republic of","Iraq","Ireland","Israel","Italy","Jamaica","Japan","Jordan","Kazakhstan","Kenya","Korea, Republic of","Kuwait","Kyrgyzstan","Latvia","Lebanon","Liberia","Lithuania","Luxembourg","Madagascar","Malawi","Malaysia","Maldives","Mali","Malta","Mauritius","Mexico","Moldova, Republic of","Monaco","Mongolia","Montenegro","Morocco","Mozambique","Myanmar","Namibia","Nepal","Netherlands","New Zealand","Nicaragua","Niger","Nigeria","Norway","Oman","Pakistan","Panama","Papua New Guinea","Paraguay","Peru","Philippines","Poland","Portugal","Qatar","Romania","Russian Federation","Rwanda","Saudi Arabia","Senegal","Serbia","Sierra Leone","Singapore","Slovakia","Slovenia","Somalia","South Africa","Spain","Sri Lanka","Sudan","Suriname","Sweden","Switzerland","Syrian Arab Republic","Taiwan, Province of China","Tajikistan","Tanzania, United Republic of","Thailand","Togo","Trinidad and Tobago","Tunisia","Turkey","Turkmenistan","Uganda","Ukraine","United Arab Emirates","United Kingdom","United States","Uruguay","Uzbekistan","Venezuela","Viet Nam","Yemen","Zambia","Zimbabwe"],
                label: "Country",
                input_html: { class: "form-select form-control" },
                wrapper_html: { class: "form-group" } %>
          </div>
          <div class="col-md-6">
            <%= f.input :swift_code, label: "SWIFT / Postal Code",
                placeholder: "Enter SWIFT code or postal address",
                input_html: { class: "form-control" },
                wrapper_html: { class: "form-group" } %>
          </div>
        </div>
      </div>

      <!-- Transfer Details -->
      <div class="tf-section">
        <div class="tf-section-header">
          <div class="tf-section-icon">💰</div>
          <div><h5>Transfer Details</h5><p>Amount and additional notes</p></div>
        </div>
        <div class="form-group mb-3">
          <label style="font-size:11px; font-weight:700; color:#5a6d8c; letter-spacing:1.2px; text-transform:uppercase; margin-bottom:6px; display:block;">Amount <span style="color:#c9a84c;">*</span></label>
          <div class="tf-amount-wrap">
            <span class="tf-currency p">$</span>
            <%= f.input :amount, label: false,
                input_html: { class: "form-control", placeholder: "0.00" },
                wrapper_html: { style: "margin:0;" } %>
          </div>
        </div>
        <div class="form-group">
          <%= f.input :notes, label: "Notes (Optional)",
              placeholder: "Add a note or reason for this transfer",
              as: :text,
              input_html: { class: "form-control", rows: 3, style: "resize:none;" },
              wrapper_html: { class: "form-group" } %>
        </div>
      </div>

      <!-- PIN -->
      <div class="tf-section">
        <div class="tf-section-header">
          <div class="tf-section-icon">🔐</div>
          <div><h5>Security Authorisation</h5><p>Enter your PIN to authorise this transfer</p></div>
        </div>
        <div class="tf-security-notice">
          🛡 Never share your PIN with anyone. Navy SEAL credit Union will never ask for your PIN via email or phone.
        </div>
        <div class="tf-pin-wrap">
          <i class="mdi mdi-lock-outline"></i>
          <%= f.input :pin, as: :password, label: "Transfer PIN",
              placeholder: "••••••",
              input_html: { class: "form-control", maxlength: 6 },
              wrapper_html: { class: "form-group" } %>
        </div>
      </div>

    </div>

    <!-- Submit -->
    <div class="tf-footer-area">
      <div style="padding-top:20px; border-top:2px solid #e8eaf0; margin-bottom:0;">
        <%= f.button :submit, class: "btn btn-warning btn-block font-weight-bold",
            style: "padding:16px; font-size:15px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; border-radius:8px; box-shadow:0 4px 20px rgba(201,168,76,0.35); display:flex; align-items:center; justify-content:center; gap:10px; color:#0a1628;" do %>
          <i class="mdi mdi-bank-transfer" style="font-size:20px;"></i>
          Initiate Transfer
        <% end %>
      </div>
    </div>

    <!-- Footer strip -->
    <div class="tf-card-footer">
      <span>Member FDIC &nbsp;·&nbsp; Equal Housing Lender</span>
      <div style="display:flex; gap:6px;">
        <span style="width:6px; height:6px; border-radius:50%; background:#c9a84c; display:block;"></span>
        <span style="width:6px; height:6px; border-radius:50%; background:#c9a84c; opacity:0.3; display:block;"></span>
        <span style="width:6px; height:6px; border-radius:50%; background:#c9a84c; opacity:0.3; display:block;"></span>
      </div>
    </div>

  <% end %>
</div>
