<footer style="background:#0a1628; font-family:'Source Sans 3',Helvetica,Arial,sans-serif;">

  <!-- Gold top bar -->
  <div style="height:3px; background:linear-gradient(90deg,#c9a84c,#e8d08a,#c9a84c);"></div>

  <!-- Main content -->
  <div class="container-fluid" style="padding:48px 40px 32px;">
    <div class="row g-4">

      <!-- Brand -->
      <div class="col-lg-4 col-md-6">
        <p style="font-family:'Playfair Display',Georgia,serif; font-size:18px; color:#fff; font-weight:700; margin:0 0 6px;">Navy's Credit Union</p>
        <p style="font-size:10px; color:#c9a84c; letter-spacing:2.5px; text-transform:uppercase; font-weight:700; margin:0 0 16px;">Member FDIC &nbsp;·&nbsp; Equal Housing Lender</p>
        <p style="font-size:13px; color:#5a6d8c; line-height:1.7; margin:0 0 20px; max-width:280px;">Banking you can trust. Serving our members with secure, reliable financial services since day one.</p>
        <div style="display:flex; gap:10px;">
          <a href="#" style="width:34px; height:34px; border-radius:50%; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); display:flex; align-items:center; justify-content:center; color:#c9a84c; text-decoration:none; font-size:15px;"><i class="mdi mdi-facebook"></i></a>
          <a href="#" style="width:34px; height:34px; border-radius:50%; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); display:flex; align-items:center; justify-content:center; color:#c9a84c; text-decoration:none; font-size:15px;"><i class="mdi mdi-twitter"></i></a>
          <a href="#" style="width:34px; height:34px; border-radius:50%; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.25); display:flex; align-items:center; justify-content:center; color:#c9a84c; text-decoration:none; font-size:15px;"><i class="mdi mdi-instagram"></i></a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="col-lg-2 col-md-6 col-6">
        <p style="font-size:10px; color:#c9a84c; letter-spacing:2px; text-transform:uppercase; font-weight:700; margin:0 0 16px;">Quick Links</p>
        <ul style="list-style:none; padding:0; margin:0;">
          <li style="margin-bottom:10px;"><%= link_to root_path, style: "font-size:13px; color:#6a7d9e; text-decoration:none;" do %><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Dashboard<% end %></li>
          <li style="margin-bottom:10px;"><%= link_to new_transfer_path, style: "font-size:13px; color:#6a7d9e; text-decoration:none;" do %><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Fund Transfer<% end %></li>
          <li style="margin-bottom:10px;"><%= link_to transactions_path, style: "font-size:13px; color:#6a7d9e; text-decoration:none;" do %><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Account Statement<% end %></li>
          <li style="margin-bottom:10px;"><%= link_to new_loan_path, style: "font-size:13px; color:#6a7d9e; text-decoration:none;" do %><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Apply for Loan<% end %></li>
          <li style="margin-bottom:10px;"><%= link_to cards_path, style: "font-size:13px; color:#6a7d9e; text-decoration:none;" do %><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Card Services<% end %></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="col-lg-2 col-md-6 col-6">
        <p style="font-size:10px; color:#c9a84c; letter-spacing:2px; text-transform:uppercase; font-weight:700; margin:0 0 16px;">Legal</p>
        <ul style="list-style:none; padding:0; margin:0;">
          <li style="margin-bottom:10px;"><a href="#" style="font-size:13px; color:#6a7d9e; text-decoration:none;"><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Privacy Policy</a></li>
          <li style="margin-bottom:10px;"><a href="#" style="font-size:13px; color:#6a7d9e; text-decoration:none;"><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Terms of Service</a></li>
          <li style="margin-bottom:10px;"><a href="#" style="font-size:13px; color:#6a7d9e; text-decoration:none;"><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Cookie Policy</a></li>
          <li style="margin-bottom:10px;"><a href="#" style="font-size:13px; color:#6a7d9e; text-decoration:none;"><span style="width:4px; height:4px; border-radius:50%; background:#c9a84c; opacity:0.6; display:inline-block; margin-right:6px; vertical-align:middle;"></span>Disclosures</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-lg-4 col-md-6">
        <p style="font-size:10px; color:#c9a84c; letter-spacing:2px; text-transform:uppercase; font-weight:700; margin:0 0 16px;">Contact Us</p>
        <ul style="list-style:none; padding:0; margin:0;">
          <li style="margin-bottom:14px; display:flex; align-items:flex-start; gap:10px;">
            <i class="mdi mdi-map-marker-outline" style="color:#c9a84c; font-size:16px; margin-top:1px;"></i>
            <span style="font-size:13px; color:#6a7d9e; line-height:1.5;">180 Water St, New York, NY 10038</span>
          </li>
          <li style="margin-bottom:14px; display:flex; align-items:center; gap:10px;">
            <i class="mdi mdi-email-outline" style="color:#c9a84c; font-size:16px;"></i>
            <a href="mailto:support@navyscreditunion.com" style="font-size:13px; color:#6a7d9e; text-decoration:none;">support@navyscreditunion.com</a>
          </li>
          <li style="margin-bottom:14px; display:flex; align-items:center; gap:10px;">
            <i class="mdi mdi-web" style="color:#c9a84c; font-size:16px;"></i>
            <a href="https://navyscreditunion.com" style="font-size:13px; color:#6a7d9e; text-decoration:none;">navyscreditunion.com</a>
          </li>
        </ul>
        <div style="display:flex; gap:8px; margin-top:16px; flex-wrap:wrap;">
          <div style="background:rgba(201,168,76,0.08); border:1px solid rgba(201,168,76,0.2); border-radius:6px; padding:6px 10px; display:flex; align-items:center; gap:5px;">
            <i class="mdi mdi-shield-check" style="color:#c9a84c; font-size:14px;"></i>
            <span style="font-size:10px; color:#8a9bbf; font-weight:600;">256-bit SSL</span>
          </div>
          <div style="background:rgba(201,168,76,0.08); border:1px solid rgba(201,168,76,0.2); border-radius:6px; padding:6px 10px; display:flex; align-items:center; gap:5px;">
            <i class="mdi mdi-bank" style="color:#c9a84c; font-size:14px;"></i>
            <span style="font-size:10px; color:#8a9bbf; font-weight:600;">FDIC Insured</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div style="border-top:1px solid #152238;">
    <div class="container-fluid" style="padding:16px 40px;">
      <div class="row align-items-center">
        <div class="col-md-6 text-center text-md-start">
          <p style="font-size:12px; color:#3a4f6a; margin:0;">© <%= Time.now.year %> Navy's Credit Union. All rights reserved.</p>
        </div>
        <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
          <p style="font-size:11px; color:#2a3a52; margin:0; letter-spacing:1px; text-transform:uppercase;">Member FDIC &nbsp;·&nbsp; Equal Housing Lender &nbsp;·&nbsp; Regulated by NCUA</p>
        </div>
      </div>
    </div>
  </div>

</footer>
